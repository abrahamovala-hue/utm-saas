# ============================================================
# UTM SaaS — Variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
# ============================================================

# PostgreSQL (Supabase, Neon ou local)
# Supabase: Settings > Database > Connection string (use o pooler na porta 6543 p/ produção)
DATABASE_URL="postgresql://user:password@localhost:5432/utm_saas"

# URL pública da aplicação (usada para montar os links de redirect)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Salt para hash de IPs (LGPD) — gere com: openssl rand -hex 32
IP_HASH_SALT="troque-por-um-valor-aleatorio-longo"

# Auth.js — segredo de assinatura dos tokens de sessão
AUTH_SECRET="gere-um-valor-aleatorio-longo"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Token do webhook Kiwify (painel do Kiwify, ao criar o webhook).
# Se preenchido, cada webhook recebido tem a assinatura validada.
KIWIFY_WEBHOOK_TOKEN=""
